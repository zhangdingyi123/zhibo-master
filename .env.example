# 后端
PORT=8081
MYSQL_DSN=zhibo:zhibo@tcp(localhost:3306)/zhibo?charset=utf8mb4&parseTime=True&loc=Local
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
FRONTEND_URL=http://localhost:5173
# 生产环境可配置多个前端域名（逗号分隔）
# 例如 FRONTEND_URLS=https://jj520.xyz,https://mgongchang.xyz
FRONTEND_URLS=
JWT_SECRET=zhibo-dev-jwt-secret-change-in-prod

