# 后端
PORT=8081
MYSQL_DSN=zhibo:zhibo@tcp(localhost:3306)/zhibo?charset=utf8mb4&parseTime=True&loc=Local
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# Kafka 跨实例 WS 广播（生产 docker-compose 默认 kafka:9092 + backend-2）
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=zhibo.room.broadcast
# INSTANCE_ID=backend-1
FRONTEND_URL=http://localhost:5173
# 生产 IP 直访（免备案，改成你的 ECS 公网 IP）
# FRONTEND_URL=http://47.97.176.185
# FRONTEND_URLS=http://47.97.176.185
FRONTEND_URLS=
JWT_SECRET=zhibo-dev-jwt-secret-change-in-prod
# 待支付订单超时关单（分钟）
PAY_TIMEOUT_MINUTES=30
# 本地上传图片存储目录（商品封面/商品图）
UPLOAD_DIR=./uploads

# ---------- AI 产品介绍 & TTS（可选）----------
# 未配置时使用模板文案 + 浏览器语音合成；配置后启用大模型文案与云端 TTS
# 支持 OpenAI 及兼容接口（通义、DeepSeek、豆包等）
# AI_API_KEY=sk-...
# AI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_TTS_MODEL=tts-1
# AI_TTS_VOICE=nova

# ---------- 生产环境额外配置（docker-compose.prod.yml）----------
# MYSQL_ROOT_PASSWORD=强密码
# MYSQL_PASSWORD=强密码
# MYSQL_DSN=zhibo:强密码@tcp(mysql:3306)/zhibo?charset=utf8mb4&parseTime=True&loc=Local
# REDIS_ADDR=redis:6379
# FRONTEND_URL=http://47.97.176.185
# FRONTEND_URLS=http://47.97.176.185
# Grafana 子路径（与 Nginx /monitor/ 一致，末尾保留 /）
# GRAFANA_ROOT_URL=http://47.97.176.185/monitor/
